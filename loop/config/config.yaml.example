# AutoResearchClaw Config
# Copy this to config.yaml and fill in your values

# ── Meta Marketing API ──────────────────────────────────────────────────────
meta:
  access_token: "YOUR_META_ACCESS_TOKEN"
  ad_account_id: "act_XXXXXXXXXX"
  app_id: "YOUR_APP_ID"
  app_secret: "YOUR_APP_SECRET"

# ── LLM (Challenger Generator) ───────────────────────────────────────────────
llm:
  provider: "anthropic"
  model: "claude-opus-4-6"          # or claude-sonnet-4-6 for lower cost
  api_key: "YOUR_ANTHROPIC_API_KEY"

# ── Loop Settings ────────────────────────────────────────────────────────────
loop:
  frequency_hours: 48               # How often to run the full loop
  min_spend_threshold: 20.0         # Min $ spent before we judge an ad
  min_impressions: 500              # Min impressions before we judge
  evaluation_window_days: 2         # Look back N days for performance data

# ── Kill Rules ───────────────────────────────────────────────────────────────
kill_rules:
  hook_rate_min: 0.15               # Kill if hook rate < 15% (Meta: 3-sec view rate)
  ctr_min: 0.005                    # Kill if CTR < 0.5%
  cpa_max_multiplier: 3.0           # Kill if CPA > 3x target CPA (Marcel's rule)

# ── Offer Config ─────────────────────────────────────────────────────────────
offer:
  name: "YOUR OFFER NAME"
  target_cpa: 50.0                  # Your CPA target in USD
  target_roas: 2.0
  awareness_stage: 3                # Schwartz 1-5 (1=unaware, 5=most aware)
  niche: "auto_insurance"           # Used to load relevant framework prompts
  platform: "meta"

# ── Notifications ────────────────────────────────────────────────────────────
notifications:
  slack_webhook: "YOUR_SLACK_WEBHOOK_URL"   # Optional: Slack pings on each cycle
  notify_on: ["harvest", "winner", "deploy", "kill"]

# ── Frameworks Path ──────────────────────────────────────────────────────────
frameworks_path: "../creative"      # Path to creative framework files

# ── Discord Notifications ────────────────────────────────────────────────────
# Add discord_webhook alongside slack_webhook in notifications section
# discord_webhook: "YOUR_DISCORD_WEBHOOK_URL"
# discord_channel_id: "1482366861650690200"  # #creative channel

# ── Qdrant Memory ────────────────────────────────────────────────────────────
qdrant:
  enabled: false                    # Set true to enable cross-campaign memory
  url: "http://37.27.228.106:6333"
  collection: "rachel-memories"
  openai_api_key: "YOUR_OPENAI_KEY"
  recall_top_k: 5                   # How many memories to pull per cycle

# ── Approval Gate ────────────────────────────────────────────────────────────
approval_gate:
  enabled: false                    # Set true to require Discord approval before deploy
  bot_token: "YOUR_DISCORD_BOT_TOKEN"
  channel_id: "1482366861650690200" # #creative channel
  allowed_reactors: []              # Discord user IDs allowed to approve (empty = anyone)
  timeout_hours: 4                  # Hours to wait before applying timeout_action
  timeout_action: "kill"            # kill | deploy | skip_and_continue
  poll_interval_seconds: 60         # How often to check for reactions
  # Gate embeds now include prediction score + angle fatigue heatmap automatically

# ── Prediction Scorer ─────────────────────────────────────────────────────────
prediction:
  enabled: true                     # Score challenger before approval gate
  min_score_to_deploy: 0            # 0 = always proceed; set to 14 to block weak creatives
  # Scores use 25-point rubric: hook_clarity + tension_desire + angle_freshness
  # + awareness_match + pattern_interrupt
  # Predicted hook rate ranges: 22-25→35-45% | 18-21→25-35% | 14-17→15-25% | <14→iterate

# ── Angle Fatigue ─────────────────────────────────────────────────────────────
angle_fatigue:
  enabled: true                     # Run fatigue analysis before generate step
  # Tiers: FRESH (<25) | WARMING (25-50) | SATURATED (51-75) | DEAD (>75)
  # Fatigue context is injected into generate prompt to steer away from DEAD angles
  # Pulls intel from Baserow (if enabled) or local intel JSON files

# ── Intel Harvest (Multi-Source) ─────────────────────────────────────────────
intel_harvest:
  enabled: false

# ── Foreplay ─────────────────────────────────────────────────────────────────
foreplay:
  api_key: "YOUR_FOREPLAY_API_KEY"
  min_running_days: 30

# ── Facebook Ads Library ─────────────────────────────────────────────────────
fb_ads_library:
  access_token: "YOUR_FB_ACCESS_TOKEN"
  min_running_days: 30

# ── YouTube ───────────────────────────────────────────────────────────────────
youtube:
  api_key: "YOUR_YOUTUBE_API_KEY"
  include_transcripts: true

# ── Anstrex ───────────────────────────────────────────────────────────────────
anstrex:
  bearer_token: "YOUR_ANSTREX_BEARER_TOKEN"  # From browser DevTools: Authorization header on native.anstrex.com
  platform: "native"            # native | push | pops
  min_running_days: 30          # Only return ads running this many days+


# ─────────────────────────────────────────────
# Baserow (intel memory + creative brief store)
# ─────────────────────────────────────────────
baserow:
  enabled: false
  email: "YOUR_BASEROW_EMAIL"
  password: "YOUR_BASEROW_PASSWORD"
  # Table IDs (pre-created in AutoResearchClaw database):
  #   intel_ads: 813 | hooks: 814 | creative_briefs: 815 | loop_results: 816

# ── Tavily (Reddit + Forum Audience Language) ────────────────────────────────
tavily:
  api_key: "YOUR_TAVILY_API_KEY"   # https://app.tavily.com
  include_news: false               # true = also search news/review sites
  max_results_per_query: 5          # Results per subreddit query (5 = ~25 total)
